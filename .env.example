# ===========================================
# CONFIGURAÇÃO PRINCIPAL - BANCO DE DADOS
# ===========================================
# Use apenas DATABASE_URL para conectar ao banco
# Formato: postgresql://usuario:senha@host:porta/database?schema=public
# 
# PRODUÇÃO (Render/Heroku/etc): Cole a URL fornecida pelo serviço
# DESENVOLVIMENTO: Use a URL do seu PostgreSQL local ou Docker

DATABASE_URL="postgresql://frotas_admin:frotas_senha_segura_2024@localhost:5433/frotas_db?schema=public"

# ===========================================
# VARIÁVEIS OPCIONAIS - APENAS PARA DOCKER
# ===========================================
# Estas variáveis são usadas APENAS se você rodar com docker-compose
# Se você usa DATABASE_URL de produção, pode comentar/ignorar estas:

# POSTGRES_USER=frotas_admin
# POSTGRES_PASSWORD=frotas_senha_segura_2024
# POSTGRES_DB=frotas_db

# ===========================================
# AUTENTICAÇÃO E SEGURANÇA
# ===========================================

# Credenciais de Login (usuário admin padrão)
LOGIN_USERNAME=admin
LOGIN_PASSWORD=casa@linda2024

# Chave secreta para JWT (MUDE em produção!)
JWT_SECRET=chave_secreta_casa_linda_frotas_2024

# ===========================================
# SERVIDOR
# ===========================================

# Porta do servidor backend
PORT=3002

# URL do Frontend (para CORS) - atualize com URL da Vercel em produção
FRONTEND_URL=http://localhost:3000
