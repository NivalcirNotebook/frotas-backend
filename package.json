{
  "name": "sistema-gestao-frotas",
  "version": "1.0.0",
  "description": "Sistema de gestão de frotas com análise de performance",
  "main": "index.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "cli": "node index.js",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "install:all": "npm install && cd client && npm install && cd ..",
    "deploy": "npm run install:all && npm run build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "prisma:migrate": "npx prisma migrate dev",
    "prisma:studio": "npx prisma studio",
    "prisma:generate": "npx prisma generate",
    "migrate:data": "node scripts/migrate-json-to-postgres.js"
  },
  "keywords": [
    "frota",
    "automóveis",
    "gestão",
    "performance"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "date-fns": "^2.30.0",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "prisma": "^5.22.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
